#!/usr/bin/env bash

set -uo pipefail

APP_NAME="gh-actions-cleanup"
VERSION="0.2.4"
APP_SUPPORT_DIR="$HOME/Library/Application Support/GH Workflow Clean"
LAST_SESSION_FILE="$APP_SUPPORT_DIR/last-session.env"
LEGACY_LAST_SESSION_FILE="$HOME/Library/Application Support/GitHub Action Clean-Up Tool/last-session.env"

HOST=""
ACCOUNT=""
OWNER=""
REPO_NAME=""
REPO_SPEC=""

DO_DISABLE=0
DO_RUNS=0
DO_ARTIFACTS=0
DO_CACHES=0
FULL_CLEANUP=0

ASSUME_YES=0
DRY_RUN=0
NO_COLOR=0
RUN_FILTER=""
TARGET_RUN_ID=""
GUIDED_MENU_MODE=0

ORIGINAL_ACCOUNT=""
SWITCHED_ACCOUNT=0
LAST_HOST=""
LAST_ACCOUNT=""
LAST_REPO_SPEC=""

C_RESET=""
C_RED=""
C_GREEN=""
C_YELLOW=""
C_BLUE=""
C_BOLD=""

supports_color() {
  [[ -t 1 ]] && [[ "${NO_COLOR}" -eq 0 ]]
}

init_colors() {
  if supports_color; then
    C_RESET=$'\033[0m'
    C_RED=$'\033[31m'
    C_GREEN=$'\033[32m'
    C_YELLOW=$'\033[33m'
    C_BLUE=$'\033[34m'
    C_BOLD=$'\033[1m'
  else
    C_RESET=""
    C_RED=""
    C_GREEN=""
    C_YELLOW=""
    C_BLUE=""
    C_BOLD=""
  fi
}

info() {
  printf "%s[info]%s %s\n" "$C_BLUE" "$C_RESET" "$*"
}

warn() {
  printf "%s[warn]%s %s\n" "$C_YELLOW" "$C_RESET" "$*"
}

success() {
  printf "%s[ok]%s %s\n" "$C_GREEN" "$C_RESET" "$*"
}

error() {
  printf "%s[error]%s %s\n" "$C_RED" "$C_RESET" "$*" >&2
}

die() {
  error "$*"
  exit 1
}

cleanup_on_exit() {
  local exit_code=$?

  trap - EXIT
  if [[ "$SWITCHED_ACCOUNT" -eq 1 && -n "$ORIGINAL_ACCOUNT" && -n "$HOST" ]]; then
    gh auth switch --hostname "$HOST" --user "$ORIGINAL_ACCOUNT" >/dev/null 2>&1 || \
      printf "[warn] Failed to restore the original GitHub account %s on %s\n" "$ORIGINAL_ACCOUNT" "$HOST" >&2
  fi

  exit "$exit_code"
}

show_wtl_banner() {
  printf "%s\n" "$C_BOLD$C_BLUE"
  cat <<'EOF'
 __        __  _______   _
 \ \      / / |__   __| | |
  \ \ /\ / /     | |    | |
   \ V  V /      | |    | |___
    \_/\_/       |_|    |_____|

 W.T.L. GH Workflow Clean
 Professional GitHub Actions cleanup for macOS
 Provided by Wayne Tech Lab LLC · www.WayneTechLab.com
EOF
  printf "%s" "$C_RESET"
}

pause_for_enter() {
  local unused=""
  read -r -p "Press Enter to continue... " unused
}

show_install_command() {
  cat <<'EOF'
One-line install for macOS:

/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/WayneTechLab/GH-Workflow-Clean/main/install.sh)"
EOF
}

load_last_session() {
  local line=""
  local key=""
  local value=""
  local source_session_file=""

  if [[ -f "$LAST_SESSION_FILE" ]]; then
    source_session_file="$LAST_SESSION_FILE"
  elif [[ -f "$LEGACY_LAST_SESSION_FILE" ]]; then
    source_session_file="$LEGACY_LAST_SESSION_FILE"
  else
    return 0
  fi

  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      HOST) LAST_HOST="$value" ;;
      ACCOUNT) LAST_ACCOUNT="$value" ;;
      REPO) LAST_REPO_SPEC="$value" ;;
    esac
  done <"$source_session_file"
}

save_last_session() {
  local previous_umask=""

  [[ -n "$HOST" && -n "$ACCOUNT" && -n "$OWNER" && -n "$REPO_NAME" ]] || return 0

  mkdir -p "$APP_SUPPORT_DIR"
  chmod 700 "$APP_SUPPORT_DIR" >/dev/null 2>&1 || true

  previous_umask="$(umask)"
  umask 077
  cat >"$LAST_SESSION_FILE" <<EOF
HOST=$HOST
ACCOUNT=$ACCOUNT
REPO=$HOST/$OWNER/$REPO_NAME
EOF
  umask "$previous_umask"
}

show_last_session() {
  [[ -n "$LAST_HOST$LAST_ACCOUNT$LAST_REPO_SPEC" ]] || return 0

  printf "%sLast session%s\n" "$C_BOLD" "$C_RESET"
  [[ -n "$LAST_HOST" ]] && printf "  Host: %s\n" "$LAST_HOST"
  [[ -n "$LAST_ACCOUNT" ]] && printf "  Account: %s\n" "$LAST_ACCOUNT"
  [[ -n "$LAST_REPO_SPEC" ]] && printf "  Repo: %s\n" "${LAST_REPO_SPEC#*/}"
  printf "\n"
}

usage() {
  cat <<EOF
${APP_NAME} ${VERSION}

GH Workflow Clean
Interactive GitHub Actions cleanup CLI for macOS terminal use.
Provided by Wayne Tech Lab LLC · www.WayneTechLab.com

Usage:
  ${APP_NAME} [options]

Options:
  --host HOST               GitHub host, for example github.com
  --account USER            GitHub account to switch to on the selected host
  --repo TARGET             Repository to clean up as OWNER/REPO, HOST/OWNER/REPO, or full GitHub URL
  --disable-workflows       Disable all workflows in the repository
  --delete-runs             Delete all workflow runs
  --run TARGET              Delete one specific workflow run by numeric ID or GitHub run URL
  --run-filter TEXT         Delete only workflow runs whose name/title/path contains TEXT
  --delete-artifacts        Delete all Actions artifacts
  --delete-caches           Delete all Actions caches
  --all                     Full cleanup: disable workflows, delete runs, artifacts, caches
  --yes                     Skip the final confirmation prompt
  --dry-run                 Show what would be deleted without changing anything
  --no-color                Disable colored output
  --version                 Show the current version
  --help                    Show this help text

Examples:
  ${APP_NAME}
  ${APP_NAME} --all
  ${APP_NAME} --repo OWNER/REPO --all --yes
  ${APP_NAME} --repo OWNER/REPO --delete-runs --run https://github.com/OWNER/REPO/actions/runs/123456789/workflow --yes
  ${APP_NAME} --repo OWNER/REPO --delete-runs --run-filter "Sync Google Analytics Data" --yes
  ${APP_NAME} --host github.com --account USERNAME --repo OWNER/REPO --delete-runs --yes
EOF
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

prompt_optional() {
  local label="$1"
  local default="${2:-}"
  local value=""

  if [[ -n "$default" ]]; then
    read -r -p "$label [$default]: " value
    value="${value:-$default}"
  else
    read -r -p "$label: " value
  fi

  trim "$value"
}

format_epoch_local() {
  local epoch="$1"

  [[ "$epoch" =~ ^[0-9]+$ ]] || return 1

  if date -r "$epoch" '+%Y-%m-%d %H:%M:%S %Z' >/dev/null 2>&1; then
    date -r "$epoch" '+%Y-%m-%d %H:%M:%S %Z'
  else
    date -d "@$epoch" '+%Y-%m-%d %H:%M:%S %Z'
  fi
}

parse_run_target() {
  local target="$1"
  local run_id=""

  if [[ "$target" =~ ^[0-9]+$ ]]; then
    printf "%s" "$target"
    return 0
  fi

  if [[ "$target" =~ /actions/runs/([0-9]+) ]]; then
    run_id="${BASH_REMATCH[1]}"
    printf "%s" "$run_id"
    return 0
  fi

  return 1
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf "%s" "$value"
}

confirm() {
  local prompt="$1"
  local default="${2:-N}"
  local answer=""

  if [[ "$ASSUME_YES" -eq 1 ]]; then
    return 0
  fi

  while true; do
    if [[ "$default" == "Y" ]]; then
      read -r -p "$prompt [Y/n] " answer
      answer="${answer:-Y}"
    else
      read -r -p "$prompt [y/N] " answer
      answer="${answer:-N}"
    fi

    case "${answer}" in
      y|Y) return 0 ;;
      n|N) return 1 ;;
      *) warn "Please answer y or n." ;;
    esac
  done
}

prompt_nonempty() {
  local label="$1"
  local default="${2:-}"
  local value=""

  while true; do
    if [[ -n "$default" ]]; then
      read -r -p "$label [$default]: " value
      value="${value:-$default}"
    else
      read -r -p "$label: " value
    fi

    value="$(trim "$value")"
    if [[ -n "$value" ]]; then
      printf "%s" "$value"
      return 0
    fi

    warn "A value is required."
  done
}

choose_from_list() {
  local title="$1"
  shift
  local -a options=("$@")
  local choice=""
  local i=0

  [[ "${#options[@]}" -gt 0 ]] || die "Internal error: no options for $title"

  printf "%s%s%s\n" "$C_BOLD" "$title" "$C_RESET" >&2
  for i in "${!options[@]}"; do
    printf "  %d) %s\n" "$((i + 1))" "${options[$i]}" >&2
  done

  while true; do
    printf "Choose 1-%s: " "${#options[@]}" >&2
    read -r choice
    [[ "$choice" =~ ^[0-9]+$ ]] || { warn "Enter a number."; continue; }
    if (( choice >= 1 && choice <= ${#options[@]} )); then
      printf "%s" "${options[$((choice - 1))]}"
      return 0
    fi
    warn "Choice out of range."
  done
}

show_start_menu() {
  local selected=""

  while true; do
    clear >/dev/null 2>&1 || true
    show_wtl_banner
    printf "\n"
    show_last_session
    selected="$(choose_from_list "Main Menu" \
      "Guided cleanup" \
      "Check GitHub login status" \
      "Show one-line installer" \
      "Exit")"

    case "$selected" in
      "Guided cleanup")
        GUIDED_MENU_MODE=1
        return 0
        ;;
      "Check GitHub login status")
        printf "\n"
        gh auth status 2>&1 || true
        printf "\n"
        pause_for_enter
        ;;
      "Show one-line installer")
        printf "\n"
        show_install_command
        printf "\n"
        pause_for_enter
        ;;
      "Exit")
        exit 0
        ;;
    esac
  done
}

parse_repo_input() {
  local input="$1"

  input="${input%/}"
  input="${input#/}"

  if [[ "$input" =~ ^https?://([^/]+)/([^/]+)/([^/]+)/?$ ]]; then
    HOST="${BASH_REMATCH[1]}"
    OWNER="${BASH_REMATCH[2]}"
    REPO_NAME="${BASH_REMATCH[3]}"
    REPO_NAME="${REPO_NAME%.git}"
    return 0
  fi

  if [[ "$input" =~ ^git@([^:]+):([^/]+)/([^/]+)\.git$ ]]; then
    HOST="${BASH_REMATCH[1]}"
    OWNER="${BASH_REMATCH[2]}"
    REPO_NAME="${BASH_REMATCH[3]}"
    return 0
  fi

  if [[ "$input" == */*/* && -n "${input%%/*}" ]]; then
    HOST="${input%%/*}"
    input="${input#*/}"
  fi

  [[ "$input" == */* ]] || die "Repository must be OWNER/REPO or HOST/OWNER/REPO"

  OWNER="${input%%/*}"
  REPO_NAME="${input##*/}"
  REPO_NAME="${REPO_NAME%.git}"
}

gh_config_file() {
  local config_path="${XDG_CONFIG_HOME:-$HOME/.config}/gh/hosts.yml"

  if [[ -f "$config_path" ]]; then
    printf "%s" "$config_path"
  fi
}

load_hosts_from_config() {
  local config_path=""

  config_path="$(gh_config_file)"
  [[ -n "$config_path" ]] || return 0

  awk '
    /^[^[:space:]][^:]*:$/ {
      host = $0
      sub(/:$/, "", host)
      print host
    }
  ' "$config_path"
}

load_active_account_for_host() {
  local host="$1"
  local config_path=""

  config_path="$(gh_config_file)"
  [[ -n "$config_path" ]] || return 0

  awk -v host="$host" '
    /^[^[:space:]][^:]*:$/ {
      current = $0
      sub(/:$/, "", current)
      in_host = (current == host)
      next
    }
    in_host && /^    user: / {
      user = $0
      sub(/^    user: /, "", user)
      print user
      exit
    }
  ' "$config_path"
}

load_accounts_for_host() {
  local host="$1"
  local config_path=""
  local active_account=""
  local accounts=""

  config_path="$(gh_config_file)"
  [[ -n "$config_path" ]] || return 0

  active_account="$(load_active_account_for_host "$host")"

  accounts="$(awk -v host="$host" -v active_account="$active_account" '
    /^[^[:space:]][^:]*:$/ {
      current = $0
      sub(/:$/, "", current)
      in_host = (current == host)
      in_users = 0
      next
    }
    in_host && /^    users:$/ {
      in_users = 1
      next
    }
    in_host && /^    [^ ]/ && $0 !~ /^    users:$/ {
      in_users = 0
    }
    in_host && in_users && /^        [^[:space:]][^:]*:$/ {
      user = $0
      sub(/^        /, "", user)
      sub(/:$/, "", user)
      state = (user == active_account ? "active" : "available")
      print user "\t" state
    }
  ' "$config_path")"

  if [[ -z "$accounts" && -n "$active_account" ]]; then
    printf "%s\tactive\n" "$active_account"
    return 0
  fi

  printf "%s\n" "$accounts"
}

load_hosts() {
  local hosts=""

  hosts="$(load_hosts_from_config)"
  if [[ -n "$hosts" ]]; then
    printf "%s\n" "$hosts"
    return 0
  fi

  gh auth status --json hosts --jq '
    .hosts
    | to_entries[]
    | select((.value | length) > 0)
    | .key
  ' 2>/dev/null || true
}

ensure_auth_for_host() {
  local host="$1"
  local accounts=""

  accounts="$(load_accounts_for_host "$host")"
  if [[ -n "$accounts" ]]; then
    return 0
  fi

  die "No authenticated GitHub account found for $host. Login first with: gh auth login -h $host"
}

select_host() {
  local -a hosts=()
  local line=""
  local default_host=""

  if [[ -n "$HOST" ]]; then
    ensure_auth_for_host "$HOST"
    return 0
  fi

  while IFS= read -r line; do
    [[ -n "$line" ]] && hosts+=("$line")
  done < <(load_hosts)

  if [[ "$GUIDED_MENU_MODE" -eq 1 ]]; then
    default_host="${LAST_HOST:-github.com}"
    if [[ "${#hosts[@]}" -eq 1 ]]; then
      default_host="${hosts[0]}"
    fi
    HOST="$(prompt_nonempty "GitHub host" "$default_host")"
    ensure_auth_for_host "$HOST"
    info "Using GitHub host $HOST"
    return 0
  fi

  if [[ "${#hosts[@]}" -eq 0 ]]; then
    HOST="$(prompt_nonempty "GitHub host" "github.com")"
    ensure_auth_for_host "$HOST"
    return 0
  fi

  if [[ "${#hosts[@]}" -eq 1 ]]; then
    HOST="${hosts[0]}"
    info "Using GitHub host $HOST"
    ensure_auth_for_host "$HOST"
    return 0
  fi

  HOST="$(choose_from_list "Available GitHub hosts" "${hosts[@]}")"
  ensure_auth_for_host "$HOST"
}

select_account() {
  local -a lines=()
  local -a menu=()
  local line=""
  local login=""
  local state=""
  local active_account=""
  local selected=""
  local seen_accounts="|"

  while IFS= read -r line; do
    [[ -n "$line" ]] && lines+=("$line")
  done < <(load_accounts_for_host "$HOST")

  if [[ "${#lines[@]}" -eq 0 ]]; then
    ensure_auth_for_host "$HOST"
    while IFS= read -r line; do
      [[ -n "$line" ]] && lines+=("$line")
    done < <(load_accounts_for_host "$HOST")
  fi

  [[ "${#lines[@]}" -gt 0 ]] || die "No authenticated accounts found for $HOST"

  for line in "${lines[@]}"; do
    IFS=$'\t' read -r login state <<<"$line"
    if [[ "$state" == "active" ]]; then
      active_account="$login"
    fi
  done

  if [[ -n "$ACCOUNT" ]]; then
    for line in "${lines[@]}"; do
      IFS=$'\t' read -r login state <<<"$line"
      if [[ "$login" == "$ACCOUNT" ]]; then
        if [[ "$ACCOUNT" != "$active_account" ]]; then
          info "Switching active GitHub account on $HOST to $ACCOUNT"
          ORIGINAL_ACCOUNT="${active_account:-}"
          SWITCHED_ACCOUNT=1
          gh auth switch --hostname "$HOST" --user "$ACCOUNT" >/dev/null || die "Failed to switch GitHub account"
        fi
        return 0
      fi
    done
    die "Authenticated account $ACCOUNT was not found on $HOST. Login first with: gh auth login -h $HOST"
  fi

  if [[ "${#lines[@]}" -eq 1 && "$GUIDED_MENU_MODE" -eq 0 ]]; then
    IFS=$'\t' read -r ACCOUNT state <<<"${lines[0]}"
    info "Using GitHub account $ACCOUNT on $HOST"
    return 0
  fi

  for line in "${lines[@]}"; do
    IFS=$'\t' read -r login state <<<"$line"
    [[ "$seen_accounts" == *"|$login|"* ]] && continue
    seen_accounts="${seen_accounts}${login}|"
    if [[ "$state" == "active" ]]; then
      menu+=("$login (active)")
    else
      menu+=("$login")
    fi
  done

  selected="$(choose_from_list "Authenticated accounts for $HOST" "${menu[@]}")"
  ACCOUNT="${selected%% *}"

  if [[ "$ACCOUNT" != "$active_account" ]]; then
    info "Switching active GitHub account on $HOST to $ACCOUNT"
    ORIGINAL_ACCOUNT="${active_account:-}"
    SWITCHED_ACCOUNT=1
    gh auth switch --hostname "$HOST" --user "$ACCOUNT" >/dev/null || die "Failed to switch GitHub account"
  fi
}

resolve_repo() {
  local repo_input=""
  local repo_default=""
  local previous_host="$HOST"

  if [[ -n "$REPO_SPEC" ]]; then
    parse_repo_input "$REPO_SPEC"
  else
    if [[ -n "$LAST_REPO_SPEC" ]]; then
      if [[ "${LAST_REPO_SPEC%%/*}" == "$HOST" ]]; then
        repo_default="${LAST_REPO_SPEC#*/}"
      else
        repo_default="$LAST_REPO_SPEC"
      fi
    fi
    repo_input="$(prompt_nonempty "GitHub repo (OWNER/REPO, HOST/OWNER/REPO, or https://HOST/OWNER/REPO)" "$repo_default")"
    parse_repo_input "$repo_input"
  fi

  REPO_SPEC="${HOST}/${OWNER}/${REPO_NAME}"

  if [[ -n "$previous_host" && -n "$HOST" && "$previous_host" != "$HOST" ]]; then
    info "Repository target switched host to $HOST"
  fi
}

verify_repo_access() {
  gh repo view "$REPO_SPEC" --json nameWithOwner >/dev/null 2>&1 || die "Cannot access repository $REPO_SPEC"
}

ensure_api_ready() {
  local status_output=""
  local remaining=""
  local reset=""
  local reset_local=""
  local auth_status_ok=1
  local api_login=""

  if ! status_output="$(gh auth status --hostname "$HOST" 2>&1)"; then
    auth_status_ok=0
    warn "GitHub authentication for $ACCOUNT on $HOST is invalid or expired."
  fi

  api_login="$(gh api --hostname "$HOST" user --jq '.login' 2>/dev/null || printf "")"
  if [[ -z "$api_login" ]]; then
    [[ "$auth_status_ok" -eq 0 ]] && printf "%s\n" "$status_output" >&2
    die "GitHub login is required for $HOST. Run 'gh auth login -h $HOST' and retry."
  fi

  remaining="$(gh api --hostname "$HOST" rate_limit --jq '.resources.core.remaining' 2>/dev/null || printf "")"
  reset="$(gh api --hostname "$HOST" rate_limit --jq '.resources.core.reset' 2>/dev/null || printf "")"

  if [[ ! "$remaining" =~ ^[0-9]+$ ]]; then
    [[ "$auth_status_ok" -eq 0 ]] && printf "%s\n" "$status_output" >&2
    die "GitHub API access failed for $HOST. Run 'gh auth login -h $HOST' and retry."
  fi

  if [[ "$remaining" =~ ^[0-9]+$ ]] && (( remaining == 0 )); then
    reset_local="$(format_epoch_local "$reset" 2>/dev/null || printf "unknown")"
    die "GitHub API core rate limit is exhausted for $ACCOUNT on $HOST. Reset at $reset_local."
  fi

  if [[ "$auth_status_ok" -eq 0 ]]; then
    warn "Stored gh auth status looks stale, but live GitHub API access is working. Continuing."
  fi
}

select_actions() {
  if [[ "$FULL_CLEANUP" -eq 1 ]]; then
    DO_DISABLE=1
    DO_RUNS=1
    DO_ARTIFACTS=1
    DO_CACHES=1
    return 0
  fi

  if (( DO_DISABLE + DO_RUNS + DO_ARTIFACTS + DO_CACHES > 0 )); then
    return 0
  fi

  if confirm "Run full cleanup for $REPO_SPEC (disable workflows, delete runs, artifacts, caches)?" Y; then
    FULL_CLEANUP=1
    DO_DISABLE=1
    DO_RUNS=1
    DO_ARTIFACTS=1
    DO_CACHES=1
    return 0
  fi

  confirm "Disable all workflows?" N && DO_DISABLE=1
  confirm "Delete all workflow runs?" N && DO_RUNS=1
  confirm "Delete all Actions artifacts?" N && DO_ARTIFACTS=1
  confirm "Delete all Actions caches?" N && DO_CACHES=1

  (( DO_DISABLE + DO_RUNS + DO_ARTIFACTS + DO_CACHES > 0 )) || die "No cleanup action selected"
}

resolve_run_filter() {
  if [[ "$DO_RUNS" -ne 1 || -n "$RUN_FILTER" || -n "$TARGET_RUN_ID" || "$ASSUME_YES" -eq 1 ]]; then
    return 0
  fi

  RUN_FILTER="$(prompt_optional "Workflow run filter (optional substring, blank for all runs)")"
}

resolve_target_run() {
  local target_value=""
  local parsed_run_id=""

  if [[ "$DO_RUNS" -ne 1 ]]; then
    return 0
  fi

  if [[ -n "$TARGET_RUN_ID" ]]; then
    parsed_run_id="$(parse_run_target "$TARGET_RUN_ID")" || die "--run must be a numeric workflow run ID or a GitHub Actions run URL"
    TARGET_RUN_ID="$parsed_run_id"
    return 0
  fi

  [[ "$ASSUME_YES" -eq 1 ]] && return 0

  target_value="$(prompt_optional "Specific run URL or ID (optional, blank for none)")"
  if [[ -n "$target_value" ]]; then
    parsed_run_id="$(parse_run_target "$target_value")" || die "Run target must be a numeric workflow run ID or a GitHub Actions run URL"
    TARGET_RUN_ID="$parsed_run_id"
  fi
}

count_from_api() {
  local path="$1"
  local jq_expr="$2"
  local output=""

  if ! output="$(gh api --hostname "$HOST" "$path" --paginate --jq "$jq_expr" 2>/dev/null)"; then
    printf "0"
    return 0
  fi

  if [[ -z "$output" ]]; then
    printf "0"
    return 0
  fi

  printf "%s\n" "$output" | awk 'NF && $0 != "null" {count++} END {print count+0}'
}

collect_api_ids() {
  local path="$1"
  local jq_expr="$2"
  local output=""

  if ! output="$(gh api --hostname "$HOST" "$path" --paginate --jq "$jq_expr" 2>/dev/null)"; then
    return 1
  fi

  if [[ -n "$output" ]]; then
    printf "%s\n" "$output" | awk 'NF && $0 != "null" {print}'
  fi
}

collect_workflow_rows() {
  local output=""

  if ! output="$(gh workflow list -R "$REPO_SPEC" -a -L 1000 --json id,name,state,path --jq '.[] | [.id, .name, .state, (.path // "")] | @tsv' 2>/dev/null)"; then
    return 1
  fi

  if [[ -n "$output" ]]; then
    printf "%s\n" "$output"
  fi
}

to_lower() {
  printf "%s" "$1" | tr '[:upper:]' '[:lower:]'
}

first_line() {
  printf "%s" "$1" | awk 'NR == 1 { sub(/[[:space:]]+$/, ""); print; exit }'
}

workflow_skip_category() {
  local name="$1"
  local state="$2"
  local path="${3:-}"
  local lowered_name=""
  local lowered_path=""

  case "$state" in
    disabled_manually|disabled_inactivity)
      printf "already_disabled"
      return 0
      ;;
    active|"")
      ;;
    *)
      printf "state:%s" "$state"
      return 0
      ;;
  esac

  lowered_name="$(to_lower "$name")"
  lowered_path="$(to_lower "$path")"

  case "$lowered_name" in
    "dependabot updates"|"copilot code review"|"copilot coding agent")
      printf "managed"
      return 0
      ;;
  esac

  case "$lowered_path" in
    *"/dependabot-"*|*"/copilot-"*)
      printf "managed"
      return 0
      ;;
  esac

  return 1
}

workflow_disable_error_is_skippable() {
  local lowered_output=""

  lowered_output="$(to_lower "$1")"
  [[ -n "$lowered_output" ]] || return 1

  case "$lowered_output" in
    *"could not find any workflows named"*)
      return 0
      ;;
    *"workflow not found"*)
      return 0
      ;;
    *"workflow does not exist"*)
      return 0
      ;;
    *"cannot disable a disabled workflow"*)
      return 0
      ;;
    *"already disabled"*)
      return 0
      ;;
    *"not enabled"*)
      return 0
      ;;
  esac

  return 1
}

collect_run_ids() {
  local output=""
  local filter=""

  if [[ -n "$TARGET_RUN_ID" ]]; then
    printf "%s\n" "$TARGET_RUN_ID"
    return 0
  fi

  if [[ -z "$RUN_FILTER" ]]; then
    collect_api_ids "repos/${OWNER}/${REPO_NAME}/actions/runs?per_page=100" '.workflow_runs[]?.id'
    return $?
  fi

  if ! output="$(gh api --hostname "$HOST" "repos/${OWNER}/${REPO_NAME}/actions/runs?per_page=100" --paginate --jq '.workflow_runs[]? | [.id, (.name // ""), (.display_title // ""), (.path // "")] | @tsv' 2>/dev/null)"; then
    return 1
  fi

  filter="$(printf "%s" "$RUN_FILTER" | tr '[:upper:]' '[:lower:]')"
  if [[ -n "$output" ]]; then
    printf "%s\n" "$output" | awk -F'\t' -v filter="$filter" '
      {
        haystack = tolower($2 "\t" $3 "\t" $4)
        if (index(haystack, filter) > 0) {
          print $1
        }
      }
    '
  fi
}

count_run_ids() {
  local output=""

  if ! output="$(collect_run_ids)"; then
    printf "0"
    return 1
  fi

  if [[ -z "$output" ]]; then
    printf "0"
    return 0
  fi

  printf "%s\n" "$output" | awk 'NF {count++} END {print count+0}'
}

delete_run_request() {
  local run_id="$1"
  local output=""

  if output="$(gh api --method DELETE --hostname "$HOST" "repos/${OWNER}/${REPO_NAME}/actions/runs/${run_id}" 2>&1)"; then
    return 0
  fi

  if [[ "$output" == *"HTTP 404"* ]]; then
    return 2
  fi

  return 1
}

show_summary() {
  local workflow_count=""
  local cache_count=""
  local run_count="0"

  printf "%sCleanup summary%s\n" "$C_BOLD" "$C_RESET"
  printf "  Host: %s\n" "$HOST"
  printf "  Account: %s\n" "$ACCOUNT"
  printf "  Repository: %s/%s\n" "$OWNER" "$REPO_NAME"
  printf "  Disable workflows: %s\n" "$([[ "$DO_DISABLE" -eq 1 ]] && printf yes || printf no)"
  printf "  Delete runs: %s\n" "$([[ "$DO_RUNS" -eq 1 ]] && printf yes || printf no)"
  printf "  Delete artifacts: %s\n" "$([[ "$DO_ARTIFACTS" -eq 1 ]] && printf yes || printf no)"
  printf "  Delete caches: %s\n" "$([[ "$DO_CACHES" -eq 1 ]] && printf yes || printf no)"
  [[ -n "$TARGET_RUN_ID" ]] && printf "  Target run ID: %s\n" "$TARGET_RUN_ID"
  [[ -n "$RUN_FILTER" ]] && printf "  Run filter: %s\n" "$RUN_FILTER"
  printf "  Dry run: %s\n" "$([[ "$DRY_RUN" -eq 1 ]] && printf yes || printf no)"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    if [[ "$DO_DISABLE" -eq 1 ]]; then
      workflow_count="$(gh workflow list -R "$REPO_SPEC" -a -L 1000 --json id --jq 'length' 2>/dev/null || printf "0")"
      printf "  Workflows found: %s\n" "${workflow_count:-0}"
    fi
    if [[ "$DO_RUNS" -eq 1 ]]; then
      run_count="$(count_run_ids)"
      printf "  Workflow runs found: %s\n" "${run_count:-0}"
    fi
    [[ "$DO_ARTIFACTS" -eq 1 ]] && printf "  Artifacts found: %s\n" "$(count_from_api "repos/${OWNER}/${REPO_NAME}/actions/artifacts?per_page=100" '.artifacts[]?.id')"
    if [[ "$DO_CACHES" -eq 1 ]]; then
      cache_count="$(gh cache list -R "$REPO_SPEC" --limit 1000 --json id --jq 'length' 2>/dev/null || printf "0")"
      printf "  Caches found (up to 1000 listed): %s\n" "${cache_count:-0}"
    fi
  fi
}

delete_runs() {
  local -a run_ids=()
  local id=""
  local ids_output=""
  local total=0
  local completed=0
  local failed=0
  local already_gone=0

  if ! ids_output="$(collect_run_ids)"; then
    warn "Could not list workflow runs. Check GitHub API rate limits and token permissions."
    return 1
  fi

  while IFS= read -r id; do
    [[ -n "$id" ]] && run_ids+=("$id")
  done <<<"$ids_output"

  total="${#run_ids[@]}"
  if [[ "$total" -eq 0 ]]; then
    info "No workflow runs found."
    return 0
  fi

  if [[ -n "$TARGET_RUN_ID" ]]; then
    info "Deleting workflow run $TARGET_RUN_ID"
  elif [[ -n "$RUN_FILTER" ]]; then
    info "Deleting $total workflow runs matching \"$RUN_FILTER\""
  else
    info "Deleting $total workflow runs"
  fi
  for id in "${run_ids[@]}"; do
    completed=$((completed + 1))

    if [[ "$DRY_RUN" -eq 1 ]]; then
      printf "  dry-run delete run %s\n" "$id"
      continue
    fi

    if delete_run_request "$id"; then
      :
    else
      case $? in
        2)
          already_gone=$((already_gone + 1))
          if [[ -n "$TARGET_RUN_ID" ]]; then
            info "Workflow run $id is already gone."
          else
            info "Workflow run $id was already removed."
          fi
          ;;
        *)
          failed=$((failed + 1))
          warn "Failed to delete run $id"
          ;;
      esac
    fi

    if (( completed % 25 == 0 || completed == total )); then
      info "Runs progress: $completed/$total"
    fi

    if (( completed % 100 == 0 )); then
      sleep 1
    fi
  done

  if [[ "$DRY_RUN" -eq 1 ]]; then
    success "Dry run complete for workflow runs"
    return 0
  elif [[ "$failed" -eq 0 ]]; then
    if [[ "$already_gone" -gt 0 ]]; then
      success "Processed $total workflow runs ($((total - already_gone)) deleted, $already_gone already gone)"
    else
      success "Deleted $total workflow runs"
    fi
    return 0
  else
    warn "Processed $total workflow runs ($((total - failed - already_gone)) deleted, $already_gone already gone, $failed failed)"
    return 1
  fi
}

delete_artifacts() {
  local -a artifact_ids=()
  local id=""
  local ids_output=""
  local total=0
  local completed=0
  local failed=0

  if ! ids_output="$(collect_api_ids "repos/${OWNER}/${REPO_NAME}/actions/artifacts?per_page=100" '.artifacts[]?.id')"; then
    warn "Could not list artifacts. Check GitHub API rate limits and token permissions."
    return 1
  fi

  while IFS= read -r id; do
    [[ -n "$id" ]] && artifact_ids+=("$id")
  done <<<"$ids_output"

  total="${#artifact_ids[@]}"
  if [[ "$total" -eq 0 ]]; then
    info "No artifacts found."
    return 0
  fi

  info "Deleting $total artifacts"
  for id in "${artifact_ids[@]}"; do
    completed=$((completed + 1))

    if [[ "$DRY_RUN" -eq 1 ]]; then
      printf "  dry-run delete artifact %s\n" "$id"
      continue
    fi

    if gh api --method DELETE --hostname "$HOST" "repos/${OWNER}/${REPO_NAME}/actions/artifacts/${id}" >/dev/null 2>&1; then
      :
    else
      failed=$((failed + 1))
      warn "Failed to delete artifact $id"
    fi

    if (( completed % 25 == 0 || completed == total )); then
      info "Artifacts progress: $completed/$total"
    fi

    if (( completed % 100 == 0 )); then
      sleep 1
    fi
  done

  if [[ "$DRY_RUN" -eq 1 ]]; then
    success "Dry run complete for artifacts"
    return 0
  elif [[ "$failed" -eq 0 ]]; then
    success "Deleted $total artifacts"
    return 0
  else
    warn "Deleted $((total - failed)) artifacts, $failed failed"
    return 1
  fi
}

delete_caches() {
  local cache_count=""

  if [[ "$DRY_RUN" -eq 1 ]]; then
    info "Dry run: caches would be deleted with gh cache delete --all"
    return 0
  fi

  if ! cache_count="$(gh cache list --repo "$REPO_SPEC" --limit 1 --json id --jq 'length' 2>/dev/null)"; then
    warn "Could not list Actions caches. Check GitHub API rate limits and token permissions."
    return 1
  fi

  if [[ ! "$cache_count" =~ ^[0-9]+$ ]]; then
    cache_count=0
  fi

  if [[ "$cache_count" -eq 0 ]]; then
    info "No Actions caches found."
    return 0
  fi

  if gh cache delete --all --succeed-on-no-caches --repo "$REPO_SPEC" >/dev/null 2>&1; then
    success "Deleted Actions caches"
    return 0
  else
    warn "Cache cleanup reported an issue"
    return 1
  fi
}

disable_workflows() {
  local -a workflows=()
  local line=""
  local id=""
  local name=""
  local state=""
  local path=""
  local workflows_output=""
  local disable_output=""
  local skip_category=""
  local error_excerpt=""
  local total=0
  local changed=0
  local failed=0
  local skipped=0
  local already_disabled=0

  if ! workflows_output="$(collect_workflow_rows)"; then
    warn "Could not list workflows. Check GitHub API rate limits and token permissions."
    return 1
  fi

  while IFS= read -r line; do
    [[ -n "$line" ]] && workflows+=("$line")
  done <<<"$workflows_output"

  total="${#workflows[@]}"
  if [[ "$total" -eq 0 ]]; then
    info "No workflows found."
    return 0
  fi

  info "Reviewing $total workflows"
  for line in "${workflows[@]}"; do
    IFS=$'\t' read -r id name state path <<<"$line"

    if skip_category="$(workflow_skip_category "$name" "$state" "$path")"; then
      case "$skip_category" in
        already_disabled)
          info "Already disabled: $name"
          already_disabled=$((already_disabled + 1))
          ;;
        managed)
          info "Skipped GitHub-managed workflow: $name"
          skipped=$((skipped + 1))
          ;;
        state:*)
          info "Skipped workflow in state ${skip_category#state:}: $name"
          skipped=$((skipped + 1))
          ;;
      esac
      continue
    fi

    if [[ "$DRY_RUN" -eq 1 ]]; then
      printf "  dry-run disable workflow %s (%s)\n" "$name" "$id"
      changed=$((changed + 1))
      continue
    fi

    if disable_output="$(gh workflow disable "$id" -R "$REPO_SPEC" 2>&1)"; then
      success "Disabled workflow: $name"
      changed=$((changed + 1))
    elif workflow_disable_error_is_skippable "$disable_output"; then
      info "Skipped unavailable workflow: $name"
      skipped=$((skipped + 1))
    else
      error_excerpt="$(first_line "$disable_output")"
      if [[ -n "$error_excerpt" ]]; then
        warn "Failed to disable workflow: $name ($error_excerpt)"
      else
        warn "Failed to disable workflow: $name"
      fi
      failed=$((failed + 1))
    fi
  done

  if [[ "$DRY_RUN" -eq 1 ]]; then
    success "Dry run complete for workflows"
    return 0
  elif [[ "$failed" -gt 0 ]]; then
    warn "Workflow disable summary: $changed disabled, $already_disabled already disabled, $skipped skipped, $failed failed"
    return 1
  elif [[ "$changed" -gt 0 ]]; then
    success "Workflow disable summary: $changed disabled, $already_disabled already disabled, $skipped skipped"
    return 0
  elif [[ "$skipped" -gt 0 ]]; then
    info "No workflow disable changes needed. $already_disabled already disabled, $skipped skipped."
    return 0
  elif [[ "$changed" -eq 0 ]]; then
    info "All workflows were already disabled."
    return 0
  else
    return 0
  fi
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --host)
        [[ $# -ge 2 ]] || die "--host requires a value"
        HOST="$2"
        shift 2
        ;;
      --account)
        [[ $# -ge 2 ]] || die "--account requires a value"
        ACCOUNT="$2"
        shift 2
        ;;
      --repo)
        [[ $# -ge 2 ]] || die "--repo requires a value"
        REPO_SPEC="$2"
        shift 2
        ;;
      --disable-workflows)
        DO_DISABLE=1
        shift
        ;;
      --delete-runs)
        DO_RUNS=1
        shift
        ;;
      --run)
        [[ $# -ge 2 ]] || die "--run requires a value"
        TARGET_RUN_ID="$2"
        DO_RUNS=1
        shift 2
        ;;
      --run-filter)
        [[ $# -ge 2 ]] || die "--run-filter requires a value"
        RUN_FILTER="$2"
        shift 2
        ;;
      --delete-artifacts)
        DO_ARTIFACTS=1
        shift
        ;;
      --delete-caches)
        DO_CACHES=1
        shift
        ;;
      --all)
        FULL_CLEANUP=1
        shift
        ;;
      --yes)
        ASSUME_YES=1
        shift
        ;;
      --dry-run)
        DRY_RUN=1
        shift
        ;;
      --no-color)
        NO_COLOR=1
        shift
        ;;
      --version)
        printf "%s\n" "$VERSION"
        exit 0
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        die "Unknown option: $1"
        ;;
    esac
  done

  if [[ -n "$REPO_SPEC" && "$REPO_SPEC" == */*/* ]]; then
    HOST="${REPO_SPEC%%/*}"
  fi
}

main() {
  local cleanup_failed=0
  local original_argc="$#"

  parse_args "$@"
  init_colors
  load_last_session
  trap cleanup_on_exit EXIT

  require_command gh

  if [[ "$original_argc" -eq 0 ]]; then
    show_start_menu
  fi

  if [[ -n "$REPO_SPEC" ]]; then
    parse_repo_input "$REPO_SPEC"
  fi

  select_host
  resolve_repo
  select_account
  ensure_api_ready
  verify_repo_access
  save_last_session
  select_actions
  resolve_target_run
  resolve_run_filter
  show_summary

  if [[ "$ASSUME_YES" -ne 1 ]]; then
    confirm "Proceed with cleanup?" N || {
      warn "Cancelled."
      exit 0
    }
  fi

  if [[ "$DO_DISABLE" -eq 1 ]] && ! disable_workflows; then
    cleanup_failed=1
  fi
  if [[ "$DO_RUNS" -eq 1 ]] && ! delete_runs; then
    cleanup_failed=1
  fi
  if [[ "$DO_ARTIFACTS" -eq 1 ]] && ! delete_artifacts; then
    cleanup_failed=1
  fi
  if [[ "$DO_CACHES" -eq 1 ]] && ! delete_caches; then
    cleanup_failed=1
  fi

  if [[ "$cleanup_failed" -eq 1 && "$DRY_RUN" -eq 1 ]]; then
    die "Dry run finished with errors for ${REPO_SPEC}"
  elif [[ "$cleanup_failed" -eq 1 ]]; then
    die "Cleanup finished with errors for ${REPO_SPEC}"
  elif [[ "$DRY_RUN" -eq 1 ]]; then
    success "Dry run finished."
  else
    success "Cleanup finished for ${REPO_SPEC}"
  fi
}

main "$@"
